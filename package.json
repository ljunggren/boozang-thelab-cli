{
  "name": "boozang-the-lab",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://localhost:9000",
  "dependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "gojs-react": "^1.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "5.2.0",
    "react-scripts": "^5.0.1",
    "react-test-renderer": "^18.3.1",
    "sass": "^1.77.6",
    "web-vitals": "^4.1.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --verbose --colors",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "test:watch": "react-scripts test",
    "eject": "react-scripts eject",
    "server": "json-server --watch data/db.json --port 9000",
    "test:e2e": "npx playwright test"
  },
  "description": "Interactive educational web app for teaching test automation concepts — clean target for playwright-cli testing",
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "json-server": "^0.17.4",
    "multiple-cucumber-html-reporter": "^3.6.2",
    "react-error-overlay": "^6.0.11",
    "wait-on": "^9.0.3"
  },
  "resolutions": {
    "//": "See https://github.com/facebook/create-react-app/issues/11773",
    "react-error-overlay": "6.0.11"
  }
}
